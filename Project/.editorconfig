[*.{cpp,h,hlsl,hlsli}]
charset = utf-8

# スペルミスをintellisense上での「エラー」として扱う
spelling_error_severity = error

# チェック対象を「識別子(変数名など)」と「コメント」に限定する
spelling_checkable_types = identifier, comment

# 辞書を英語(米国)に固定する
spelling_language = en-US

# 自分の辞書を作れるように標準の除外辞書設定はそのまま使用
spelling_use_default_exclusion_dictionaries = true

# 自分の除外辞書を設定
spelling_exclusion_path = ./exclusion.dic